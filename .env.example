# Base URL of the AgentOS backend (FastAPI on Cloud Run).
# Local dev:
NEXT_PUBLIC_API_URL=http://localhost:8080
# Production example:
# NEXT_PUBLIC_API_URL=https://agentos-backend-xxxxx.run.app

# Google OAuth Web Client ID (same value as the backend GOOGLE_CLIENT_ID).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# OpenRouter API key (server-side only) - powers the top-bar stats
# (tokens used, credits left, 30-day spend). Get one at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=
